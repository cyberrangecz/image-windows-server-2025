export VAULT_ADDR='https://192.168.54.53:8200'
export VAULT_SKIP_VERIFY=true
vault login -method=oidc role=image

export AWS_ACCESS_KEY_ID="$(vault kv get -field=access_key secret/terraform/aws-credentials)"
export AWS_SECRET_ACCESS_KEY="$(vault kv get -field=secret_key secret/terraform/aws-credentials)"
export AWS_SSE_CUSTOMER_KEY="$(vault kv get -field=sse_customer_key secret/images/images_sse)"

export IMAGES_AWS_ACCESS_KEY_ID="$(vault kv get -field=access_key secret/images/aws-credentials)"
export IMAGES_AWS_SECRET_ACCESS_KEY="$(vault kv get -field=secret_key secret/images/aws-credentials)"

for line in $(vault kv get -mount secret -format json crczp-images-credentials | jq -r '.data.data | to_entries[] | "\(.key)=\(.value)"'); do
    export "$line"
done

for line in $(vault kv get -mount secret -format json images/application-credentials | jq -r '.data.data | to_entries[] | "\(.key)=\(.value)"'); do
    export "$line"
done
export TF_VAR_PROJECT_URL=$(git remote get-url origin | sed 's|git@.*:|https://github.com/|')
export OS_IDENTITY_API_VERSION=3
export OS_INTERFACE=public
export OS_INSECURE=true
